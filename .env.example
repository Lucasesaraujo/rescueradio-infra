API_IMAGE=rescueradio-api:local
WEB_IMAGE=rescueradio-web:local

API_HTTP_PORT=8000
API_UDP_PORT=9000
WEB_PORT=4200
KONG_PROXY_PORT=8001
KONG_ADMIN_PORT=8002
GATEWAY_WS_URL=ws://localhost:8000
GATEWAY_HTTP_URL=http://localhost:8001/api
JWT_SECRET=rescueradio-local-secret
CORS_ALLOW_ORIGINS=*

POSTGRES_DB=rescueradio
POSTGRES_USER=rescueradio
POSTGRES_PASSWORD=rescueradio
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rescueradio:rescueradio@postgres:5432/rescueradio

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

DISCONNECT_GRACE_SECONDS=2

KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_AUDIT_TOPIC=rescueradio.audit

PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
