API_IMAGE=rescueradio-api:local
WEB_IMAGE=rescueradio-web:local

# Public domain used by the browser.
PUBLIC_URL=https://rescue.devflowapp.space
GATEWAY_HTTP_URL=https://rescue.devflowapp.space/api
GATEWAY_WS_URL=wss://rescue.devflowapp.space
CORS_ALLOW_ORIGINS=https://rescue.devflowapp.space

# Public observability domains.
PROMETHEUS_PUBLIC_URL=https://prometheus.devflowapp.space
GRAFANA_PUBLIC_URL=https://grafana.devflowapp.space
LOKI_PUBLIC_URL=https://loki.devflowapp.space

# Ports can stay bound locally if an external reverse proxy terminates TLS.
API_HTTP_PORT=8000
WEB_PORT=4200
KONG_PROXY_PORT=8001
KONG_ADMIN_PORT=8002

# Replace every secret below before deploying.
JWT_SECRET=change-me-use-a-long-random-secret
BOOTSTRAP_ADMIN_KEY=change-me-use-a-one-time-bootstrap-key
POSTGRES_DB=rescueradio
POSTGRES_USER=rescueradio
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://rescueradio:change-me-postgres-password@postgres:5432/rescueradio

REDIS_URL=redis://redis:6379/0
DISCONNECT_GRACE_SECONDS=2

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_AUDIT_TOPIC=rescueradio.audit

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Keep observability ports private unless the reverse proxy protects them.
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
